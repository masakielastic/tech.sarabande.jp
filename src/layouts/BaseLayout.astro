---
interface Props {
	title?: string;
	description?: string;
	type?: "website" | "article";
}

const {
	title = "tech.sarabande.jp",
	description = "Astro と Cloudflare Workers で運用する技術メモ。",
	type = "website",
} = Astro.props;

const siteTitle = "tech.sarabande.jp";
const pageTitle = title === siteTitle ? siteTitle : `${title} | ${siteTitle}`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="ja">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="canonical" href={canonicalUrl} />
		<title>{pageTitle}</title>
		<meta name="description" content={description} />
		<meta property="og:type" content={type} />
		<meta property="og:site_name" content={siteTitle} />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={description} />
	</head>
	<body>
		<header class="site-header">
			<a class="site-title" href="/">tech.sarabande.jp</a>
		</header>
		<main class="site-main">
			<slot />
		</main>
		<footer class="site-footer">
			<small>&copy; {new Date().getFullYear()} tech.sarabande.jp</small>
		</footer>
	</body>
</html>

<style is:global>
	:root {
		color-scheme: light;
		--color-bg: #f8f7f4;
		--color-surface: #ffffff;
		--color-text: #1f2933;
		--color-muted: #637083;
		--color-border: #d7dde5;
		--color-accent: #0f766e;
		--color-accent-soft: #e0f2f1;
		--font-sans:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
			"Segoe UI", sans-serif;
		--font-mono:
			"SFMono-Regular", Consolas, "Liberation Mono", Menlo, monospace;
	}

	* {
		box-sizing: border-box;
	}

	html {
		background: var(--color-bg);
		color: var(--color-text);
		font-family: var(--font-sans);
		line-height: 1.75;
	}

	body {
		margin: 0;
		min-height: 100vh;
	}

	a {
		color: var(--color-accent);
		text-underline-offset: 0.18em;
	}

	a:hover {
		text-decoration-thickness: 0.12em;
	}

	img {
		max-width: 100%;
		height: auto;
	}

	.site-header,
	.site-main,
	.site-footer {
		width: min(100% - 32px, 760px);
		margin-inline: auto;
	}

	.site-header {
		padding: 28px 0 18px;
	}

	.site-title {
		color: var(--color-text);
		font-size: 1rem;
		font-weight: 700;
		text-decoration: none;
	}

	.site-main {
		padding: 24px 0 56px;
	}

	.site-footer {
		border-top: 1px solid var(--color-border);
		color: var(--color-muted);
		padding: 24px 0 36px;
	}

	.hero {
		border-bottom: 1px solid var(--color-border);
		margin-bottom: 32px;
		padding-bottom: 28px;
	}

	.hero h1,
	.post-header h1,
	.not-found h1 {
		font-size: clamp(2rem, 6vw, 3rem);
		letter-spacing: 0;
		line-height: 1.15;
		margin: 0 0 14px;
	}

	.hero p,
	.post-description,
	.not-found p {
		color: var(--color-muted);
		font-size: 1.08rem;
		margin: 0;
	}

	.post-list {
		display: grid;
		gap: 20px;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.post-card {
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: 8px;
		padding: 20px;
	}

	.post-card h2 {
		font-size: 1.35rem;
		line-height: 1.35;
		margin: 0 0 8px;
	}

	.post-card h2 a {
		color: var(--color-text);
		text-decoration: none;
	}

	.post-card h2 a:hover {
		color: var(--color-accent);
	}

	.post-card p {
		color: var(--color-muted);
		margin: 10px 0 0;
	}

	.post-meta {
		color: var(--color-muted);
		display: flex;
		flex-wrap: wrap;
		font-size: 0.92rem;
		gap: 8px 12px;
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		margin-top: 14px;
	}

	.tag {
		background: var(--color-accent-soft);
		border-radius: 999px;
		color: #0f5f59;
		font-size: 0.82rem;
		line-height: 1;
		padding: 7px 10px;
	}

	.post-header {
		border-bottom: 1px solid var(--color-border);
		margin-bottom: 32px;
		padding-bottom: 26px;
	}

	.post-content {
		font-size: 1.02rem;
	}

	.post-content h2 {
		font-size: 1.65rem;
		line-height: 1.3;
		margin: 2.2em 0 0.7em;
	}

	.post-content h3 {
		font-size: 1.25rem;
		line-height: 1.35;
		margin: 2em 0 0.65em;
	}

	.post-content p,
	.post-content ul,
	.post-content ol {
		margin: 1em 0;
	}

	.post-content li + li {
		margin-top: 0.25em;
	}

	.post-content code {
		background: #edf2f7;
		border-radius: 4px;
		font-family: var(--font-mono);
		font-size: 0.92em;
		padding: 0.12em 0.3em;
	}

	.post-content pre {
		background: #17202a;
		border-radius: 8px;
		color: #f6f8fa;
		overflow-x: auto;
		padding: 16px;
	}

	.post-content pre code {
		background: transparent;
		border-radius: 0;
		color: inherit;
		display: block;
		font-size: 0.92rem;
		padding: 0;
	}

	.back-link {
		display: inline-flex;
		margin-top: 36px;
	}

	.not-found {
		padding: 52px 0;
	}

	@media (max-width: 520px) {
		.site-header,
		.site-main,
		.site-footer {
			width: min(100% - 24px, 760px);
		}

		.site-main {
			padding-top: 14px;
		}

		.post-card {
			padding: 16px;
		}
	}
</style>
