{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "tech-sarabande-jp",
  "compatibility_date": "2026-05-25",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page"
  },
  "routes": [
    {
      "pattern": "tech.sarabande.jp",
      "custom_domain": true
    }
  ]
}
